# Cloudflare Pages / Wrangler configuration for local emulation
name = "sora-gallery"
compatibility_date = "2024-04-01"
pages_build_output_dir = "dist"

[[d1_databases]]
binding = "DB" # Pages Functions で context.env.DB としてアクセスする名前
database_name = "sora-gallery-likes-db"
database_id = "<PRODUCTION_D1_DATABASE_ID>"

# Preview 環境では本番 DB を使い回さず、preview 専用 D1 を使う。
[[env.preview.d1_databases]]
binding = "DB"
database_name = "sora-gallery-likes-db-preview"
database_id = "<PREVIEW_D1_DATABASE_ID>"
